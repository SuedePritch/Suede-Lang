type Finding {
  question: text
  category: obj
  summary: obj
  confidence: text
}

type Report {
  question: text
  sub_question_count: num
  report: obj
}

# break a research question into sub-questions
pipeline decompose(question: text) -> list {
  const parts ~= extract(question, fields: [sub_questions]) with fast
  return parts.sub_questions
}

# research a single sub-question
pipeline research_one(question: text) -> Finding {
  parallel {
    const answer ~= generate(question, format: [answer, confidence, sources]) with smart retry 2
    const category ~= classify(question, into: [factual, opinion, technical, conceptual]) with fast
  }
  const summary ~= compress(answer, max: 200) with fast
  return @Finding { question, category, summary, confidence: answer.confidence }
}

# synthesize multiple findings into a final report
pipeline synthesize(findings: list) -> text {
  # build a combined context from all findings
  for f in findings into summaries {
    emit "${f.category}: ${f.summary}"
  }
  const context = summaries |> join("\n\n")
  const report ~= generate(context, format: [introduction, key_findings, conclusion]) with smart retry 2
  return report
}

# main entry point — full research pipeline
main(question: text) -> Report {
  # decompose into sub-questions
  const sub_questions = decompose(question)

  # research each sub-question
  for q in sub_questions into findings {
    const finding = research_one(q)
    emit finding
  }

  # synthesize into a final report
  const report = synthesize(findings)

  return @Report {
    question,
    sub_question_count: len(sub_questions),
    report
  }
}
