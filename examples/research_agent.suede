init {
  api_keys {
    gemini = env("GEMINI_API_KEY")
  }

  model fast = "gemini-3.5-flash" {
    provider = "gemini"
    temperature = 0.2
    max_tokens = 512
  }

  model deep = "gemini-2.5-pro-preview-06-05" {
    provider = "gemini"
    temperature = 0.5
    max_tokens = 8192
  }
}

type Finding {
  question: text
  category: obj
  summary: obj
  confidence: text
}

type Report {
  question: text
  sub_question_count: num
  report: obj
}

# break a research question into sub-questions
pipeline decompose(question: text) -> list {
  let parts ~= extract(question, fields: [sub_questions]) with fast
  return parts.sub_questions
}

# research a single sub-question
pipeline research_one(question: text) -> Finding {
  parallel {
    let answer ~= generate(question, format: [answer, confidence, sources]) with deep retry 2
    let category ~= classify(question, into: [factual, opinion, technical, conceptual]) with fast
  }
  let summary ~= compress(answer, max: 200) with fast
  return @Finding { question, category, summary, confidence: answer.confidence }
}

# synthesize multiple findings into a final report
pipeline synthesize(findings: list) -> text {
  # build a combined context from all findings
  for f in findings into summaries {
    emit "${f.category}: ${f.summary}"
  }
  let context = summaries |> join("\n\n")
  let report ~= generate(context, format: [introduction, key_findings, conclusion]) with deep retry 2
  return report
}

# main entry point — full research pipeline
pipeline research(question: text) -> Report {
  # decompose into sub-questions
  let sub_questions = decompose(question)

  # research each sub-question
  for q in sub_questions into findings {
    let finding = research_one(q)
    emit finding
  }

  # synthesize into a final report
  let report = synthesize(findings)

  return @Report {
    question,
    sub_question_count: len(sub_questions),
    report
  }
}
