type Article {
  title: any
  author: any
  type: obj
  body: obj
  summary: obj
}

init {
  api_keys {
    gemini = env("GEMINI_API_KEY")
  }

  model fast = "gemini-3.5-flash" {
    provider = "gemini"
    temperature = 0.3
    max_tokens = 512
  }

  model creative = "gemini-2.5-pro-preview-06-05" {
    provider = "gemini"
    temperature = 0.9
    max_tokens = 4096
  }
}

pipeline process_article(raw: text) -> Article {
  # extract metadata — cheap
  let meta ~= extract(raw, fields: [title, author, topic, word_count]) with fast

  # classify the content type to decide how to handle it
  let content_type ~= classify(raw, into: [news, opinion, tutorial, review]) with fast

  if content_type.label == "tutorial" {
    # tutorials get expanded with more detail
    let expanded ~= expand(raw, max: 2000) with creative
    let summary ~= compress(expanded, max: 200) with fast
    return @Article {
      title: meta.title,
      author: meta.author,
      type: content_type,
      body: expanded,
      summary
    }
  } else {
    # everything else gets compressed and rewritten
    let body ~= rewrite(raw, style: "professional") with creative
    let summary ~= compress(body, max: 140) with fast
    return @Article {
      title: meta.title,
      author: meta.author,
      type: content_type,
      body,
      summary
    }
  }
}
